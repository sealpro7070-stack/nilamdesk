{
  "manifest_version": 3,
  "name": "Nilam Auto",
  "version": "1.0.0",
  "description": "Save your AINS session to Nilam Auto for automatic monthly submissions.",
  "permissions": ["activeTab", "scripting", "storage", "cookies"],
  "host_permissions": [
    "https://ains.moe.gov.my/*",
    "https://ains-api.moe.gov.my/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nilam Auto"
  },
  "content_scripts": [
    {
      "matches": ["https://ains.moe.gov.my/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
